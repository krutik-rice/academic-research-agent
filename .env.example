# Google Scholar search via SerpAPI (https://serpapi.com — free tier: 100 searches/month)
SERPAPI_API_KEY=your_serpapi_api_key_here

# Optional — override arXiv API base URL
ARXIV_BASE_URL=https://export.arxiv.org/api/

# Optional — local storage path for papers and summaries (default: ./data)
STORAGE_PATH=./data
