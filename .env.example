# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — higher rate limits on Semantic Scholar API
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# Optional — override arXiv API base URL
ARXIV_BASE_URL=https://export.arxiv.org/api/

# Optional — local storage path for papers and summaries (default: ./data)
STORAGE_PATH=./data
